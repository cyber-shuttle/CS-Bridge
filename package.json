{
	"name": "cybershuttle",
	"displayName": "CyberShuttle",
	"publisher": "cybershuttle",
	"description": "Manage SSH sessions, HPC jobs, Dev Tunnels, and remote storage from VS Code",
	"license": "Apache-2.0",
	"icon": "resources/cybershuttle.png",
	"keywords": [
		"ssh",
		"hpc",
		"slurm",
		"dev-tunnel",
		"remote"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/cyber-shuttle/CS-Bridge.git"
	},
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.98.0"
	},
	"extensionKind": [
		"ui"
	],
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "cybershuttle.auth",
				"title": "Sign In",
				"icon": "$(account)"
			},
			{
				"command": "cybershuttle.openMetrics",
				"title": "Session Metrics",
				"icon": "$(graph)"
			},
			{
				"command": "cybershuttle.exportMetrics",
				"title": "CyberShuttle: Export Metrics"
			},
			{
				"command": "cybershuttle.reportMetrics",
				"title": "CyberShuttle: Report Metrics"
			},
			{
				"command": "cybershuttle.addRemote",
				"title": "Add Storage",
				"icon": "$(add)"
			},
			{
				"command": "cybershuttle.storagesGoBack",
				"title": "Go Back",
				"icon": "$(arrow-left)"
			},
			{
				"command": "cybershuttle.storagesGoForward",
				"title": "Go Forward",
				"icon": "$(arrow-right)"
			},
			{
				"command": "cybershuttle.storagesGoHome",
				"title": "Go Home",
				"icon": "$(home)"
			},
			{
				"command": "cybershuttle.storagesRefresh",
				"title": "Refresh",
				"icon": "$(refresh)"
			},
			{
				"command": "cybershuttle.switchSession",
				"title": "CyberShuttle: Switch Session"
			},
			{
				"command": "cybershuttle.reinstallDependencies",
				"title": "CyberShuttle: Reinstall Dependencies"
			},
			{
				"command": "cybershuttle.startLinkspan",
				"title": "CyberShuttle: Start Linkspan"
			},
			{
				"command": "cybershuttle.restartLinkspan",
				"title": "CyberShuttle: Restart Linkspan"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "cybershuttle.auth",
					"when": "view == cybershuttle.sessionsView",
					"group": "navigation@1"
				},
				{
					"command": "cybershuttle.openMetrics",
					"when": "view == cybershuttle.sessionsView",
					"group": "navigation@2"
				},
				{
					"command": "cybershuttle.storagesGoBack",
					"when": "view == cybershuttle.storagesView",
					"group": "navigation@1"
				},
				{
					"command": "cybershuttle.storagesGoForward",
					"when": "view == cybershuttle.storagesView",
					"group": "navigation@2"
				},
				{
					"command": "cybershuttle.storagesGoHome",
					"when": "view == cybershuttle.storagesView",
					"group": "navigation@3"
				},
				{
					"command": "cybershuttle.storagesRefresh",
					"when": "view == cybershuttle.storagesView",
					"group": "navigation@4"
				},
				{
					"command": "cybershuttle.addRemote",
					"when": "view == cybershuttle.storagesView",
					"group": "navigation@5"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "cybershuttle",
					"title": "CyberShuttle",
					"icon": "resources/cybershuttle.svg"
				}
			]
		},
		"views": {
			"cybershuttle": [
				{
					"type": "webview",
					"id": "cybershuttle.sessionsView",
					"name": "Sessions"
				},
				{
					"type": "webview",
					"id": "cybershuttle.storagesView",
					"name": "Storages"
				}
			]
		},
		"configuration": {
			"title": "CyberShuttle",
			"properties": {
				"cybershuttle.adminServerUrl": {
					"type": "string",
					"default": "https://admin.dev.cybershuttle.org",
					"description": "URL of the CS-Bridge admin server for metrics reporting."
				},
				"cybershuttle.tunnelProvider": {
					"type": "string",
					"enum": [
						"devtunnel",
						"frp"
					],
					"default": "devtunnel",
					"description": "Tunnel provider for linkspan connections. 'devtunnel' uses Microsoft Dev Tunnels, 'frp' uses a self-hosted FRP relay."
				},
				"cybershuttle.frpServerUrl": {
					"type": "string",
					"default": "",
					"description": "FRP relay server address (host:port). Required when tunnelProvider is 'frp'."
				},
				"cybershuttle.frpApiKey": {
					"type": "string",
					"default": "",
					"description": "API key for the FRP relay server. Required when tunnelProvider is 'frp'."
				},
				"cybershuttle.enableFilesystemSync": {
					"type": "boolean",
					"default": true,
					"markdownDescription": "**Experimental.** When enabled, CS-Bridge sets up overlay filesystems, FUSE mounts, and mutagen sync between local and remote workspaces. When disabled, sessions open a plain Remote-SSH window without any filesystem mounting or sync — the user browses remote files directly."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src",
		"test": "vscode-test",
		"package": "npx @vscode/vsce package",
		"install-ext": "code --install-extension cybershuttle-0.0.1.vsix",
		"dev": "npm install && npm run compile && npm run package && npm run install-ext"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "20.x",
		"@types/vscode": "^1.98.0",
		"@typescript-eslint/eslint-plugin": "^8.25.0",
		"@typescript-eslint/parser": "^8.25.0",
		"@vscode/test-cli": "^0.0.10",
		"@vscode/test-electron": "^2.4.1",
		"eslint": "^9.21.0",
		"typescript": "^5.7.3"
	},
	"dependencies": {
		"@vscode/codicons": "^0.0.44",
		"sql.js": "^1.14.0"
	},
	"__metadata": {
		"installedTimestamp": 1773025451091,
		"targetPlatform": "undefined",
		"size": 627168
	}
}