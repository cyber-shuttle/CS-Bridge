{
  "name": "cybershuttle",
  "displayName": "CyberShuttle",
  "publisher": "cybershuttle",
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/cyber-shuttle/CS-Bridge.git"
  },
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.98.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cybershuttle.auth",
        "title": "CyberShuttle: Auth"
      },
      {
        "command": "cybershuttle.openMetrics",
        "title": "Session Metrics",
        "icon": "$(graph)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cybershuttle.openMetrics",
          "when": "view == cybershuttle.workspacesView",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cybershuttle",
          "title": "CyberShuttle",
          "icon": "resources/cybershuttle.svg"
        }
      ]
    },
    "views": {
      "cybershuttle": [
        {
          "type": "webview",
          "id": "cybershuttle.workspacesView",
          "name": "Workspaces"
        },
        {
          "type": "webview",
          "id": "cybershuttle.serversView",
          "name": "Servers"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "npx @vscode/vsce package",
    "install-ext": "code --install-extension cybershuttle-0.0.1.vsix",
    "dev": "npm install && npm run compile && npm run package && npm run install-ext"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.98.0",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.21.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.44",
    "sql.js": "^1.14.0"
  }
}
