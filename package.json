{
	"name": "csbridge",
	"displayName": "CS Bridge",
	"publisher": "cybershuttle",
	"description": "Manage SSH sessions and HPC jobs from VS Code",
	"license": "Apache-2.0",
	"icon": "resources/csbridge.png",
	"keywords": [
		"ssh",
		"hpc",
		"slurm",
		"dev-tunnel",
		"remote"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/cyber-shuttle/CS-Bridge.git"
	},
	"version": "0.0.2",
	"engines": {
		"vscode": "^1.98.0"
	},
	"extensionKind": [
		"ui"
	],
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "csbridge",
					"title": "CS Bridge",
					"icon": "resources/csbridge.svg"
				}
			]
		},
		"views": {
			"csbridge": [
				{
					"type": "webview",
					"id": "csbridge.sessionsView",
					"name": "Sessions",
					"icon": "resources/csbridge.svg"
				},
				{
					"type": "webview",
					"id": "csbridge.hostsView",
					"name": "SSH Hosts",
					"icon": "resources/csbridge.svg",
					"when": "!csbridge.remote"
				},
				{
					"type": "webview",
					"id": "csbridge.statsView",
					"name": "Stats",
					"icon": "resources/csbridge.svg",
					"when": "!csbridge.remote"
				}
			]
		},
		"commands": [
			{
				"command": "csbridge.newSession",
				"title": "New Session",
				"category": "CS Bridge",
				"icon": "$(add)"
			},
			{
				"command": "csbridge.addHost",
				"title": "Add SSH Host",
				"category": "CS Bridge",
				"icon": "$(add)"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "csbridge.newSession",
					"group": "navigation@1",
					"when": "view == csbridge.sessionsView && !csbridge.remote"
				},
				{
					"command": "csbridge.addHost",
					"group": "navigation@1",
					"when": "view == csbridge.hostsView"
				}
			],
			"commandPalette": [
				{
					"command": "csbridge.newSession",
					"when": "false"
				},
				{
					"command": "csbridge.addHost",
					"when": "false"
				}
			]
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run check-types && node esbuild.js --production",
		"compile": "node esbuild.js",
		"watch": "node esbuild.js --watch",
		"check-types": "tsc -p ./ && tsc -p src/ui/tsconfig.json",
		"lint": "eslint src",
		"test": "node --import tsx --test src/modules/*.test.ts src/ui/logic/*.test.ts",
		"package": "npx @vscode/vsce package",
		"install-ext": "code --install-extension csbridge-0.0.2.vsix",
		"dev": "npm install && npm run package && npm run install-ext"
	},
	"devDependencies": {
		"@types/node": "^20.19.43",
		"@types/shell-quote": "^1.7.5",
		"@types/vscode": "^1.120.0",
		"@typescript-eslint/eslint-plugin": "^8.61.1",
		"@typescript-eslint/parser": "^8.61.1",
		"@vscode/codicons": "^0.0.45",
		"esbuild": "^0.28.1",
		"eslint": "^9.39.4",
		"tsx": "^4.22.4",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@microsoft/dev-tunnels-connections": "^1.3.48",
		"@microsoft/dev-tunnels-contracts": "^1.3.48",
		"@microsoft/dev-tunnels-management": "^1.3.48",
		"@vscode-elements/elements": "^2.5.1",
		"posix-getopt": "^1.2.1",
		"preact": "^10.29.2",
		"shell-quote": "^1.8.4",
		"ssh-config": "^5.1.0"
	}
}
